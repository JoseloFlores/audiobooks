# Ruta base donde se almacenarán las configuraciones y los audiolibros.
# Reemplaza '/home/user' con la ruta absoluta que prefieras.
BOOK_STACK_PATH=/home/user

# Zona horaria para los contenedores.
# Puedes encontrar tu zona horaria en: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Argentina/Buenos_Aires
